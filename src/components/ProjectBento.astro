---
import type { Project } from '../data/portfolio';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<section class="bento-container" aria-label="Proyectos">
  {projects.map((project, index) => (
    <article
      class={`bento-card ${
        index === 0 || index === 3 ? 'bento-card--large' : ''
      }`}
      style={{
        backgroundImage: `linear-gradient(135deg, rgba(16, 23, 34, 0.7) 0%, rgba(8, 10, 15, 0.8) 100%), url('${project.image}')`,
        backgroundSize: 'cover',
        backgroundPosition: 'center',
      }}
    >
      <div class="bento-content">
        <h3>{project.title}</h3>
        <p>{project.description}</p>
      </div>
      <div class="bento-accent"></div>
    </article>
  ))}
</section>

<style>
  .bento-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  @media (min-width: 768px) {
    .bento-container {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .bento-card--large {
      grid-column: span 2;
    }
  }

  .bento-card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 1rem;
    transition: all 0.3s ease;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    cursor: pointer;
    background-attachment: fixed;
  }

  .bento-content {
    padding: 1.5rem;
    z-index: 2;
    position: relative;
  }

  .bento-content h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text);
  }

  .bento-content p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .bento-accent {
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    opacity: 0.05;
    pointer-events: none;
  }

  .bento-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
  }

  .bento-card:hover .bento-accent {
    opacity: 0.1;
  }

  @media (max-width: 640px) {
    .bento-container {
      grid-template-columns: 1fr;
    }

    .bento-card--large {
      grid-column: span 1;
    }

    .bento-card {
      min-height: 180px;
    }

    .bento-content {
      padding: 1rem;
    }
  }
</style>
