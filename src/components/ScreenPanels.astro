---
import { projects, secondaryTechnologies, technologies } from '../data/portfolio';
---

<div class="screen-panel" data-panel="projects" aria-hidden="true">
  <button class="panel-close" type="button" data-close-panel aria-label="Cerrar">X</button>
  <p class="section-eyebrow text-sm font-semibold uppercase">Proyectos</p>
  <h2 class="section-title mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">Bento de trabajos destacados.</h2>
  <div class="mt-8 grid auto-rows-[180px] gap-4 md:grid-cols-2">
    {projects.map((project) => (
      <article class="project-card relative overflow-hidden rounded-lg border p-6">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-cyan-300 via-emerald-300 to-amber-300 opacity-80"></div>
        <h3 class="text-2xl font-semibold tracking-tight">{project.title}</h3>
        <p class="project-copy mt-3 max-w-sm text-sm leading-6">{project.description}</p>
      </article>
    ))}
  </div>
</div>

<div class="screen-panel" data-panel="tech" aria-hidden="true">
  <button class="panel-close" type="button" data-close-panel aria-label="Cerrar">X</button>
  <p class="section-eyebrow text-sm font-semibold uppercase">Tecnologias</p>
  <h2 class="section-title mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">Stack para construir rapido.</h2>
  <p class="section-copy mt-4 max-w-2xl text-base leading-7">
    Herramientas para interfaces, APIs, datos y experiencias web modernas.
  </p>
  <div class="tech-track mt-8 flex overflow-hidden border-y py-5">
    <div class="tech-marquee flex min-w-full shrink-0 items-center gap-4 pr-4">
      {[...technologies, ...technologies].map((tech) => (
        <span class="tech-pill min-w-max rounded-full border px-6 py-3 text-sm font-semibold shadow-sm">{tech}</span>
      ))}
    </div>
    <div class="tech-marquee flex min-w-full shrink-0 items-center gap-4 pr-4" aria-hidden="true">
      {[...technologies, ...technologies].map((tech) => (
        <span class="tech-pill min-w-max rounded-full border px-6 py-3 text-sm font-semibold shadow-sm">{tech}</span>
      ))}
    </div>
  </div>
  <div class="tech-track mt-4 flex overflow-hidden border-y py-5">
    <div class="tech-marquee-reverse flex min-w-full shrink-0 items-center gap-4 pr-4">
      {[...secondaryTechnologies, ...secondaryTechnologies].map((tech) => (
        <span class="tech-pill min-w-max rounded-full border px-6 py-3 text-sm font-semibold shadow-sm">{tech}</span>
      ))}
    </div>
    <div class="tech-marquee-reverse flex min-w-full shrink-0 items-center gap-4 pr-4" aria-hidden="true">
      {[...secondaryTechnologies, ...secondaryTechnologies].map((tech) => (
        <span class="tech-pill min-w-max rounded-full border px-6 py-3 text-sm font-semibold shadow-sm">{tech}</span>
      ))}
    </div>
  </div>
</div>

<div class="screen-panel" data-panel="contact" aria-hidden="true">
  <button class="panel-close" type="button" data-close-panel aria-label="Cerrar">X</button>
  <p class="section-eyebrow text-sm font-semibold uppercase">Contacto</p>
  <h2 class="section-title mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">Hablemos de tu proximo proyecto.</h2>
  <p class="section-copy mt-4 max-w-2xl text-base leading-7">
    Estoy disponible para construir interfaces, productos web y prototipos interactivos.
  </p>
  <div class="mt-8 flex flex-wrap gap-3">
    <a class="primary-button rounded-full px-5 py-3 text-sm font-semibold transition" href="mailto:hola@example.com">hola@example.com</a>
    <button class="secondary-button rounded-full px-5 py-3 text-sm font-semibold transition" type="button" data-open-panel="projects">Ver proyectos</button>
  </div>
</div>

<div class="panel-backdrop" data-panel-backdrop></div>
