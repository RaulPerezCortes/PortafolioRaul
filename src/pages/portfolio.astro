---
import '../styles/global.css';
import { projects, technologies } from '../data/portfolio';
import ProjectBento from '../components/ProjectBento.astro';
import TechCloud from '../components/TechCloud.astro';

import TagCloud from '../components/TagCloud.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio | Portafolio</title>
    <script is:inline>
      try {
        if (sessionStorage.getItem('studio-door-transition') === '1') {
          document.documentElement.dataset.doorTransition = '1';
          sessionStorage.removeItem('studio-door-transition');
        }
      } catch {}
    </script>
    <style is:inline>
      html[data-door-transition="1"],
      html[data-door-transition="1"] body {
        background: #000 !important;
      }

      html[data-door-transition="1"] body > * {
        visibility: hidden !important;
      }
    </style>
  </head>
  <body class="content-page">
    <main class="content-shell">
      <a class="back-link" href="/">Volver al estudio</a>
      <p class="eyebrow">Portfolio</p>
      <h1>Experiencia, proyectos y skills.</h1>
      <section class="content-grid">
        <article>
          <h2>Experiencia</h2>
          <p>Resume aqui tus roles, responsabilidades y resultados principales.</p>
        </article>
      </section>
      <ProjectBento projects={projects} />
      <TagCloud />

    </main>
    <script is:inline>
      if (document.documentElement.dataset.doorTransition === '1') {
        window.addEventListener('load', () => {
          window.setTimeout(() => {
            delete document.documentElement.dataset.doorTransition;
          }, 260);
        }, { once: true });
      }
    </script>
  </body>
</html>
