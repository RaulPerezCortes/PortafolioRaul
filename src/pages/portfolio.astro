---
import '../styles/global.css';
import { projects, technologies } from '../data/portfolio';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Portfolio | Portafolio</title>
  </head>
  <body class="content-page">
    <main class="content-shell">
      <a class="back-link" href="/">Volver al estudio</a>
      <p class="eyebrow">Portfolio</p>
      <h1>Experiencia, proyectos y skills.</h1>
      <section class="content-grid">
        <article>
          <h2>Experiencia</h2>
          <p>Resume aqui tus roles, responsabilidades y resultados principales.</p>
        </article>
        {projects.map((project) => (
          <article>
            <h2>{project.title}</h2>
            <p>{project.description}</p>
          </article>
        ))}
      </section>
      <section class="skill-list" aria-label="Skills">
        {technologies.map((tech) => <span>{tech}</span>)}
      </section>
    </main>
  </body>
</html>
