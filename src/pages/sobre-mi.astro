---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sobre mi | Portafolio</title>
  </head>
  <body class="content-page">
    <main class="content-shell about-main">
      <a class="back-link" href="/">Volver al estudio</a>
      
      <!-- NOMBRE CON EFECTO DE ESCRITURA -->
      <div class="hero-section">
        <h1 class="typing-name">Raul Developer</h1>
        <div class="accent-line"></div>
      </div>

      <!-- DESCRIPCIÓN -->
      <section class="description-section">
        <p class="description-text">
          Desarrollador web apasionado por crear interfaces modernas, interactivas y de alto rendimiento. 
          Especializado en React, TypeScript y arquitecturas frontend escalables. 
          Me encanta transformar ideas en productos digitales excepcionales.
        </p>
      </section>

      <!-- BOTONES -->
      <section class="actions-section">
        <div class="button-group">
          <a href="/cv-raul-2024.pdf" class="btn btn-primary" download>
            <span class="btn-icon">↓</span>
            Descargar CV
          </a>
          <a href="mailto:raul@example.com" class="btn btn-secondary">
            <span class="btn-icon">✉</span>
            Email
          </a>
          <a href="https://linkedin.com" target="_blank" class="btn btn-secondary">
            <span class="btn-icon">in</span>
            LinkedIn
          </a>
          <a href="https://github.com" target="_blank" class="btn btn-secondary">
            <span class="btn-icon">⚡</span>
            GitHub
          </a>
        </div>
      </section>
    </main>

    <style>
      .about-main {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .hero-section {
        margin: 2rem 0 3rem 0;
      }

      .typing-name {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 900;
        margin: 0;
        line-height: 1.1;
        background: linear-gradient(135deg, #22d3ee 0%, #a855f7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: typing 3.5s steps(30, end) forwards, blink 0.7s infinite;
        border-right: 3px solid #22d3ee;
        padding-right: 0.5rem;
        letter-spacing: -0.02em;
      }

      @keyframes typing {
        from {
          width: 0;
          border-right-color: #22d3ee;
        }
        to {
          width: 100%;
          border-right-color: transparent;
        }
      }

      @keyframes blink {
        0%, 49% {
          border-right-color: #22d3ee;
        }
        50%, 100% {
          border-right-color: transparent;
        }
      }

      .accent-line {
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, #22d3ee 0%, #a855f7 100%);
        margin-top: 1rem;
        border-radius: 2px;
        animation: expandWidth 1.5s ease-out 3.5s forwards;
        opacity: 0;
      }

      @keyframes expandWidth {
        from {
          width: 0;
          opacity: 0;
        }
        to {
          width: 60px;
          opacity: 1;
        }
      }

      .description-section {
        margin: 3rem 0;
        max-width: 600px;
        animation: fadeInUp 0.8s ease-out 4.2s forwards;
        opacity: 0;
      }

      .description-text {
        font-size: 1.1rem;
        line-height: 1.8;
        opacity: 0.9;
        margin: 0;
        color: var(--color-text, #f8fafc);
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .actions-section {
        margin-top: 3rem;
        animation: fadeInUp 0.8s ease-out 4.8s forwards;
        opacity: 0;
      }

      .button-group {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.8rem 1.5rem;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        border-radius: 0.375rem;
        transition: all 0.3s ease;
        border: 1px solid transparent;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .btn-icon {
        font-size: 1.1rem;
        font-weight: 700;
      }

      .btn-primary {
        background: linear-gradient(135deg, #22d3ee 0%, #a855f7 100%);
        color: #000;
        border-color: transparent;
      }

      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(34, 211, 238, 0.25);
      }

      .btn-secondary {
        background: transparent;
        color: #f8fafc;
        border-color: rgba(34, 211, 238, 0.4);
      }

      .btn-secondary:hover {
        background: rgba(34, 211, 238, 0.1);
        border-color: #22d3ee;
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(34, 211, 238, 0.15);
      }

      @media (max-width: 640px) {
        .typing-name {
          font-size: 2rem;
        }

        .description-section {
          margin: 2rem 0;
        }

        .button-group {
          gap: 0.75rem;
        }

        .btn {
          padding: 0.7rem 1.2rem;
          font-size: 0.85rem;
        }
      }
    </style>
  </body>
</html>
